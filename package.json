    "@react-aria/ssr": "3.10.0",
    "@reduxjs/toolkit": "2.2.3",
    "@restart/hooks": "0.6.2",
    "@restart/ui": "1.9.4",
    "bcryptjs": "^3.0.3",
    "bootstrap": "5.3.3",
    "chart.js": "4.4.1",
    "cra-template-redux": "2.0.0",
    "graphql": "16.8.1",
